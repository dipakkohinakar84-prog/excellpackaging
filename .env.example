VITE_POCKETBASE_URL=http://127.0.0.1:8090
VITE_PUSH_API_URL=http://127.0.0.1:8091/api/send-push
VITE_MAIL_API_URL=http://127.0.0.1:8091/api/send-mail
VITE_VAPID_PUBLIC_KEY=your_public_key
VITE_REALTIME_MODE=polling

POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your_admin_password
PUSH_RELAY_PORT=8091
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key
VAPID_SUBJECT=mailto:admin@example.com

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=erp@yourdomain.com
SMTP_PASS=your_hostinger_mailbox_password
MAIL_FROM=erp@yourdomain.com
MAIL_FROM_NAME=Excell Packaging ERP
MAIL_REPLY_TO=sales@yourdomain.com

IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=erp@yourdomain.com
IMAP_PASS=your_hostinger_mailbox_password
INBOUND_DEPARTMENT=Office
INBOUND_SENDER_USER_ID=1
AUTO_SYNC_INBOX=true
MAIL_SYNC_INTERVAL_MS=30000
MAIL_SYNC_LOOKBACK_DAYS=2
MAIL_SYNC_FETCH_LIMIT=50
